default_platform(:ios)

PROJECT = "AiveraEcho.xcodeproj"
SCHEME  = "AiveraEcho"
BUNDLE  = "solutions.aivera.echo"

# Temp keychain used by match on CI. Password is ephemeral — keychain is
# created fresh each run and discarded with the runner.
KEYCHAIN_NAME     = "echo_ci"
KEYCHAIN_PASSWORD = "echo_ci_temp_password"

platform :ios do

  # Build a signed App Store archive and upload it to TestFlight.
  # Triggered by the ios-testflight.yml workflow on v* tags.
  desc "Build and upload to TestFlight"
  lane :beta do
    # 1. App Store Connect API key (from CI secrets) — used for signing-asset
    #    management AND the TestFlight upload. No Apple ID / password needed.
    api_key = app_store_connect_api_key(
      key_id:       ENV.fetch("ASC_KEY_ID"),
      issuer_id:    ENV.fetch("ASC_ISSUER_ID"),
      key_content:  ENV.fetch("ASC_KEY_P8"),
      is_key_content_base64: false
    )

    # 2. Fresh temp keychain — match installs the distribution cert into it
    #    so the subsequent build_app can find the private key.
    create_keychain(
      name:             KEYCHAIN_NAME,
      password:         KEYCHAIN_PASSWORD,
      default_keychain: true,
      unlock:           true,
      timeout:          3600,
      lock_when_sleeps: false
    )

    # 3. Generate the Xcode project from project.yml (it's not committed).
    Dir.chdir("..") { sh("xcodegen generate") }

    # 3b. Verify Info.plist on disk has CFBundleIconName and the AppIcon set
    #     contains pre-rendered PNG sizes. The workflow renders them via sips
    #     before xcodegen runs, so by here we expect 11 icon-NNN.png files.
    Dir.chdir("..") do
      sh("echo '--- Sources/AiveraEcho/Info.plist ---'")
      sh("grep -A1 CFBundleIconName Sources/AiveraEcho/Info.plist || true")
      sh("echo '--- AppIcon catalog ---'")
      sh("ls Resources/Assets.xcassets/AppIcon.appiconset/ || true")
    end

    # 4. Fetch (or, on first run, create + push) the distribution cert +
    #    provisioning profile. readonly:false lets the very first CI run
    #    bootstrap the cert repo; later runs just reuse what's there.
    match(
      type:              "appstore",
      app_identifier:    BUNDLE,
      api_key:           api_key,
      readonly:          false,
      keychain_name:     KEYCHAIN_NAME,
      keychain_password: KEYCHAIN_PASSWORD
    )

    # 5. Build. Unique build number from the CI run number so each upload is
    #    accepted by TestFlight (passed via xcargs so we don't mutate the
    #    generated .xcodeproj). DEVELOPMENT_TEAM must be set as a build
    #    setting so xcodebuild stamps the archive with the team — without it
    #    -exportArchive errors with "No Team Found in Archive".
    build_number = ENV["GITHUB_RUN_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")
    team_id = ENV.fetch("APPLE_TEAM_ID")
    build_app(
      project:       PROJECT,
      scheme:        SCHEME,
      configuration: "Release",
      export_method: "app-store",
      xcargs:        "CURRENT_PROJECT_VERSION=#{build_number} DEVELOPMENT_TEAM=#{team_id}",
      export_options: {
        method:               "app-store",
        signingStyle:         "manual",
        teamID:               team_id,
        provisioningProfiles: {
          BUNDLE => "match AppStore #{BUNDLE}"
        }
      }
    )

    # 5b. NUCLEAR: inspect the built IPA and force-inject CFBundleIconName +
    #     legacy icon PNGs at the bundle root, then re-sign. After four
    #     consecutive runs of altool rejecting the upload with "missing
    #     CFBundleIconName" — despite the key being in Sources/Info.plist,
    #     in XcodeGen's info.properties, and in INFOPLIST_KEY_* — we stop
    #     trusting xcodebuild's plist handling and modify the IPA directly.
    Dir.chdir("..") do
      ipa = "AiveraEcho.ipa"
      work = "_ipa_fix"
      sh("rm -rf #{work} && mkdir #{work}")
      sh("unzip -o #{ipa} -d #{work} > /dev/null")

      app = "#{work}/Payload/AiveraEcho.app"
      plist = "#{app}/Info.plist"

      sh("echo '--- IPA bundle contents (icon-related) ---'")
      sh("ls -la #{app} | grep -iE '(icon|car|plist)' || true")
      sh("echo '--- IPA Info.plist BEFORE fix ---'")
      sh("/usr/libexec/PlistBuddy -c 'Print' #{plist} | head -60 || true")
      sh("echo '--- CFBundleIconName check ---'")
      sh("/usr/libexec/PlistBuddy -c 'Print :CFBundleIconName' #{plist} 2>&1 || echo 'KEY MISSING'")

      # Force-inject CFBundleIconName.
      sh("/usr/libexec/PlistBuddy -c 'Add :CFBundleIconName string AppIcon' #{plist} 2>/dev/null || /usr/libexec/PlistBuddy -c 'Set :CFBundleIconName AppIcon' #{plist}")

      # Copy legacy icon PNGs into the bundle root with the names Apple's
      # validator looks for. These satisfy errors 90022 (120) and 90023 (152)
      # even if the asset catalog ones don't.
      icon_src = "Resources/Assets.xcassets/AppIcon.appiconset"
      legacy_names = {
        120 => "AppIcon60x60@2x.png",
        180 => "AppIcon60x60@3x.png",
        152 => "AppIcon76x76@2x.png",
        167 => "AppIcon83.5x83.5@2x.png",
        76  => "AppIcon76x76.png",
        80  => "AppIcon40x40@2x.png",
        120 => "AppIcon40x40@3x.png",  # duplicates 120; overwrites
      }
      [120, 152, 167, 180, 76, 80, 60, 87, 58, 40, 29, 20].each do |size|
        src = "#{icon_src}/icon-#{size}.png"
        dst = "#{app}/AppIcon-#{size}.png"
        sh("[ -f #{src} ] && cp #{src} #{dst} || true")
      end
      # Also drop the two specific names altool grumbles about:
      sh("cp #{icon_src}/icon-120.png #{app}/AppIcon60x60@2x.png || true")
      sh("cp #{icon_src}/icon-152.png #{app}/AppIcon76x76@2x.png || true")

      sh("echo '--- IPA Info.plist AFTER fix ---'")
      sh("/usr/libexec/PlistBuddy -c 'Print :CFBundleIconName' #{plist}")

      # Re-sign the bundle (matchcert in keychain). codesign needs the
      # entitlements xml extracted from the original signature.
      sh("codesign -d --entitlements :- #{app} > #{work}/entitlements.plist 2>/dev/null || true")
      identity = sh("security find-identity -v -p codesigning #{KEYCHAIN_NAME} | grep 'iPhone Distribution\\|Apple Distribution' | head -n1 | awk -F'\"' '{print $2}'").strip
      raise "No distribution identity found in keychain" if identity.empty?
      UI.message("Re-signing with identity: #{identity}")
      sh("codesign --force --sign '#{identity}' --entitlements #{work}/entitlements.plist --timestamp #{app}")

      # Re-zip into the IPA filename fastlane will pick up.
      sh("rm #{ipa}")
      sh("cd #{work} && zip -qr ../#{ipa} Payload")
      UI.success("Patched IPA written: #{ipa}")
    end

    # 6. Upload to TestFlight. Skip waiting for Apple's processing so CI exits
    #    promptly; the build appears in TestFlight a few minutes later.
    upload_to_testflight(
      api_key:                          api_key,
      ipa:                              "../AiveraEcho.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external:              false
    )
  end
end
