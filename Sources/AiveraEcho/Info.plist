<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    Most keys (CFBundleDisplayName, usage descriptions, UIBackgroundModes, etc.)
    are merged in by XcodeGen via project.yml's `info.properties` block.
    The keys below are hard-coded here because XcodeGen's merge has been
    observed not to propagate them into the final compiled Info.plist.

    CFBundleIconName must be set to the asset-catalog icon-set name so
    Apple's App Store Connect validator can find the bundled icons.
  -->
  <key>CFBundleIconName</key>
  <string>AppIcon</string>
</dict>
</plist>
