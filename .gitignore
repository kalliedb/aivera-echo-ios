# Generated by XcodeGen — never committed
*.xcodeproj/
*.xcworkspace/

# Build output
build/
DerivedData/
.swiftpm/
*.o
*.app
*.ipa
*.dSYM

# Xcode user-specific
xcuserdata/
*.xcuserdatad/
*.xcuserstate

# Swift Package Manager
Packages/
Package.resolved

# CocoaPods (not used, but defensive)
Pods/
*.lock

# macOS
.DS_Store

# IDE
.vscode/
.idea/

# Secrets / signing — managed via GitHub Actions secrets + local Keychain
*.p12
*.mobileprovision
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
ExportOptions.plist
.env
.env.local

# Dropped-in CI log exports (not source)
*.pdf
*.docx
